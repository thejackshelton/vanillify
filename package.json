{
  "name": "vanillify",
  "version": "1.1.0",
  "description": "Tailwind CSS to vanilla CSS converter powered by Tailwind CSS and oxc-parser",
  "license": "MIT",
  "bin": {
    "vanillify": "./dist/cli.mjs"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "scripts": {
    "build": "vp pack",
    "test": "vp test",
    "test:watch": "vp test watch",
    "lint": "vp lint",
    "fmt": "vp fmt",
    "check": "vp check",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "citty": "^0.2.2",
    "consola": "^3.4.2",
    "magic-regexp": "^0.11.0",
    "oxc-parser": "^0.123.0",
    "oxc-walker": "^0.7.0",
    "pathe": "^2.0.3",
    "tailwindcss": "~4.2.2",
    "tinyglobby": "^0.2.15"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "typescript": "^5.5.0",
    "vite-plus": "0.1.15"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.25.0"
}
