{
  "name": "vanillify",
  "version": "0.0.1",
  "type": "module",
  "description": "Tailwind CSS to vanilla CSS converter powered by UnoCSS and oxc-parser",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "bin": {
    "vanillify": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsdown",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@unocss/core": "^66.6.7",
    "@unocss/preset-wind4": "^66.6.7",
    "oxc-parser": "^0.123.0",
    "oxc-walker": "^0.7.0"
  },
  "devDependencies": {
    "tsdown": "^0.21.7",
    "typescript": "^5.5.0",
    "vitest": "^4.1.2"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT"
}
